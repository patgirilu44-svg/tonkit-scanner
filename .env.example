# TonKit Scanner — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Supabase — get from Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ-your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=eyJ-your-service-role-key-here

# Lemon Squeezy — get from app.lemonsqueezy.com
LEMONSQUEEZY_API_KEY=your-ls-api-key
LS_STORE_ID=your-store-id
LS_VARIANT_ID=your-variant-id-for-49-product
LS_WEBHOOK_SECRET=your-webhook-secret

# App
# Salt for report ID generation — generate with: openssl rand -hex 32
SCAN_SALT=your-random-32-char-hex-string

# Your deployed app URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
