{
  "extends": ["next/core-web-vitals"],
  "rules": {
    "@typescript-eslint/ban-ts-comment": [
      "error",
      {
        "ts-expect-error": {
          "descriptionFormat": "^: TODO\\(T\\d+\\): .+$"
        },
        "ts-ignore": true,
        "ts-nocheck": true,
        "ts-check": false
      }
    ],
    "no-console": ["warn", { "allow": ["warn", "error"] }]
  }
}
